#!/bin/bash
# Pre-commit hook to prevent committing sensitive information
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔒 Running security checks...${NC}"

# Exit flag
FAILED=0

# Check for common credential patterns in staged changes
check_patterns() {
    local file="$1"
    
    # Patterns to look for (case-insensitive)
    local patterns=(
        'password\s*[:=].*[a-zA-Z0-9]'
        'api[_-]?key\s*[:=]'
        'secret\s*[:=]'
        'token\s*[:=]'
        'credentials\s*[:=]'
        'smtp[_-]?pass'
        'email[_-]?pass'
    )
    
    for pattern in "${patterns[@]}"; do
        if git diff --cached "$file" | grep -iE "$pattern" > /dev/null 2>&1; then
            echo -e "${RED}❌ SECURITY: Potential credential pattern detected in $file${NC}"
            echo -e "   Pattern: ${YELLOW}$pattern${NC}"
            FAILED=1
            return 1
        fi
    done
}

# Check specific credential strings
check_credentials() {
    local file="$1"
    
    # List of specific credentials to prevent
    local credentials=(
        'Vi9948146882'
        'admin123'
    )
    
    for cred in "${credentials[@]}"; do
        if git diff --cached "$file" | grep -i "$cred" > /dev/null 2>&1; then
            echo -e "${RED}❌ SECURITY: Known credential detected in $file${NC}"
            echo -e "   Credential: ${YELLOW}$cred${NC}"
            FAILED=1
            return 1
        fi
    done
}

# Check for .env files being committed
check_env_files() {
    local file="$1"
    
    if [[ "$file" =~ ^\.env ]]; then
        if [[ "$file" != ".env.example" ]] && [[ "$file" != ".env.local.example" ]]; then
            echo -e "${RED}❌ SECURITY: Environment file being committed: $file${NC}"
            echo -e "   ${YELLOW}Environment files should never be committed!${NC}"
            echo -e "   ${YELLOW}Make sure it's in .gitignore${NC}"
            FAILED=1
            return 1
        fi
    fi
}

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✅ No files to check${NC}"
    exit 0
fi

# Check each staged file
for file in $STAGED_FILES; do
    # Skip certain file types
    if [[ "$file" =~ \.(lock|png|jpg|jpeg|gif|pdf|zip)$ ]]; then
        continue
    fi
    
    # Skip documentation files (they contain credential examples but are safe)
    if [[ "$file" =~ \.(md|example|txt)$ ]] || [[ "$file" =~ \.githooks ]]; then
        continue
    fi
    
    check_patterns "$file" || true
    check_credentials "$file" || true
    check_env_files "$file" || true
done

# Report results
if [ $FAILED -eq 1 ]; then
    echo ""
    echo -e "${RED}❌ COMMIT BLOCKED: Security issues detected${NC}"
    echo ""
    echo -e "${YELLOW}Security Tips:${NC}"
    echo "1. Never commit actual credentials"
    echo "2. Use .env.local (in .gitignore) for sensitive data"
    echo "3. Use placeholder values in documentation"
    echo "4. Use environment variables in code"
    echo "5. Run 'git diff --cached' to review your changes"
    echo ""
    echo -e "${YELLOW}To fix:${NC}"
    echo "1. Remove sensitive data from your changes"
    echo "2. Run: git reset (to unstage)"
    echo "3. Edit files to remove credentials"
    echo "4. Run: git add (to re-stage clean files)"
    echo "5. Try committing again"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ Security checks passed${NC}"
echo -e "${GREEN}✅ All staged files are safe to commit${NC}"
exit 0
