# Email Configuration for Contact Form
# ⚠️ IMPORTANT: Never commit actual credentials to git
# Copy this file to .env.local and add your real credentials
# .env.local is already in .gitignore and will NOT be committed

# Email address for contact form
EMAIL_USER=your-email@yourdomain.com

# Email password or app-specific password
# For Hostinger: Generate in Email account settings
# For Gmail: Use App Password (not regular password)
# For other providers: Use provider-specific app password
EMAIL_PASSWORD=your-secure-password-here

# Optional: SMTP Server Configuration (if different from default)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
